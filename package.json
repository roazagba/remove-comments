{
  "name": "remove-comments-rahy",
  "displayName": "remove-comments-rahy",
  "description": "A powerful VS Code extension to remove comments from your code files",
  "version": "1.0.0",
  "publisher": "roazagba",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.removeAllComments",
        "title": "RAHY: Remove all comments"
      },
      {
        "command": "extension.removeLineComments",
        "title": "RAHY: Remove only line comments (//, #, etc.)"
      },
      {
        "command": "extension.removeBlockComments",
        "title": "RAHY: Remove only block comments (/* */, <!-- -->, etc.)"
      }
    ],
    "keybindings": [
      {
        "command": "extension.removeAllComments",
        "key": "ctrl+shift+k",
        "mac": "cmd+shift+k",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "extension.removeLineComments",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "extension.removeBlockComments",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "extension.removeAllComments",
          "group": "navigation"
        },
        {
          "command": "extension.removeLineComments",
          "group": "navigation"
        },
        {
          "command": "extension.removeBlockComments",
          "group": "navigation"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/roazagba/remove-comments-rahy.git"
  },
  "bugs": {
    "url": "https://github.com/roazagba/remove-comments-rahy/issues"
  },
  "homepage": "https://github.com/roazagba/remove-comments-rahy/blob/main/README.md",
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/strip-comments": "^2.0.4",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "strip-comments": "^2.0.1"
  }
}
